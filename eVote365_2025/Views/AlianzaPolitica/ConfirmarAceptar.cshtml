@using Evote365.Core.Application.ViewModels.Dirigente.AlianzaPolitica
@using Evote366.Core.Domain.Common.Enums
@model ConfirmarAccionAlianzaViewModel
@{
    ViewData["Title"] = "Confirmar Aceptación";
    Layout = "_LayoutDirigente";
}

<div class="confirm-card confirm-success mt-4 text-center">
    <div class="icon-wrap mx-auto">
        <i class="bi bi-hand-thumbs-up"></i>
    </div>
    <h2>¿Aceptar solicitud de alianza?</h2>
    <p class="confirm-copy">¿Desea aceptar la solicitud enviada por <strong>@Model.NombrePartido (@Model.SiglasPartido)</strong>?</p>

    <form asp-action="ConfirmarAceptar" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <div class="form-actions justify-content-center">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle me-2"></i>Cancelar
            </a>
            <button type="submit" class="btn btn-success">
                <i class="bi bi-check2-circle me-2"></i>Aceptar
            </button>
        </div>
    </form>
</div>
