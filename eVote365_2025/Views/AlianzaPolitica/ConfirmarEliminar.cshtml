@using Evote365.Core.Application.ViewModels.Dirigente.AlianzaPolitica
@using Evote366.Core.Domain.Common.Enums
@model ConfirmarAccionAlianzaViewModel
@{
    ViewData["Title"] = "Confirmar Eliminación";
    Layout = "_LayoutDirigente";
}

<div class="confirm-card confirm-danger mt-4 text-center">
    <div class="icon-wrap mx-auto">
        <i class="bi bi-trash3"></i>
    </div>
    <h2>¿Eliminar solicitud de alianza?</h2>
    <p class="confirm-copy">¿Desea eliminar la solicitud enviada a <strong>@Model.NombrePartido (@Model.SiglasPartido)</strong>?</p>

    <form asp-action="ConfirmarEliminar" method="post">
        <input type="hidden" asp-for="SolicitudId" />
        <div class="form-actions justify-content-center">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left-circle me-2"></i>Cancelar
            </a>
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-trash me-2"></i>Eliminar
            </button>
        </div>
    </form>
</div>
