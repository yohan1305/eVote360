@using Evote365.Core.Application.ViewModels.Dirigente.AlianzaPolitica
@using Evote366.Core.Domain.Common.Enums
@model CrearSolicitudAlianzaViewModel
@{
    ViewData["Title"] = "Crear Solicitud de Alianza";
    Layout = "_LayoutDirigente";
}

<div class="form-shell mt-4">
    <div class="form-card">
        <div class="page-hero mb-4">
            <div>
                <h2>Crear Solicitud de Alianza</h2>
                <p class="form-intro">Seleccione el partido con el que desea proponer una alianza electoral.</p>
            </div>
        </div>

        <form asp-action="Crear" method="post">
            <div class="form-group">
                <label asp-for="PartidoReceptorId" class="form-label"></label>
                <select asp-for="PartidoReceptorId" asp-items="@(new SelectList(Model.PartidosDisponibles, "Id", "Nombre"))" class="form-select"></select>
                <span asp-validation-for="PartidoReceptorId" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle me-2"></i>Cancelar
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-send me-2"></i>Enviar Solicitud
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
