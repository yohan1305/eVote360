@model CandidatoIndexViewModel
@using Evote365.Core.Application.ViewModels.Dirigente.Candidato
@using Evote366.Core.Domain.Common.Enums
@{
    Layout = "~/Views/Shared/_LayoutDirigente.cshtml";
    ViewData["Title"] = "Candidatos";
}

<section class="page-panel">
    <div class="page-hero">
        <div>
            <h2>Candidatos de mi partido</h2>
            <p>Consulta, edita y administra los perfiles de campaña registrados.</p>
        </div>
    </div>

    @if (Model.PuedeModificar)
    {
        <a asp-action="Crear" class="btn btn-primary mb-3">
            <i class="bi bi-plus-circle"></i> Agregar Candidato
        </a>
    }

    <div class="page-table">
        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Nombre</th>
                    <th>Puesto</th>
                    <th>Estado</th>
                    <th>Foto</th>
                    @if (Model.PuedeModificar)
                    {
                        <th>Acciones</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var c in Model.Candidatos)
                {
                    <tr>
                        <td>@($"{c.Nombre} {c.Apellido}")</td>
                        <td>
                            @if (c.PuestosAsignados.Any())
                            {
                                <ul class="mb-0">
                                    @foreach (var p in c.PuestosAsignados)
                                    {
                                        <li>@p</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">Sin puesto asignado</span>
                            }
                        </td>
                        <td>@c.Estado</td>
                        <td>
                            @if (!string.IsNullOrEmpty(c.FotoUrl))
                            {
                                <img src="@c.FotoUrl" alt="Foto" width="60" height="60" class="rounded" />
                            }
                        </td>
                        @if (Model.PuedeModificar)
                        {
                            <td>
                                <div class="action-stack">
                                    <a asp-action="Editar" asp-route-id="@c.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </a>
                                    <a asp-action="ConfirmarEstado" asp-route-id="@c.Id" asp-route-activar="@(c.Estado == EstadoEntidad.Inactivo)" class="btn btn-sm btn-secondary">
                                        @(c.Estado == EstadoEntidad.Activo ? "Desactivar" : "Activar")
                                    </a>
                                </div>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
