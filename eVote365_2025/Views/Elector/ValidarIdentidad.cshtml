@using Evote365.Core.Application.ViewModels.Elector
@model ValidarIdentidadViewModel

@{
    ViewData["Title"] = "Validar Identidad";
    Layout = "~/Views/Shared/_LayoutElector.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0 mt-4">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">Validar Identidad</h4>
            </div>
            <div class="card-body">
                <form id="form-cedula">
                    <input type="hidden" id="cedulaOriginal" value="@Model.Cedula" />

                    <div class="form-group mb-3">
                        <label for="fotoCedula" class="form-label">Foto de la cédula (frontal)</label>
                        <input type="file" id="fotoCedula" accept="image/*" class="form-control" required />
                    </div>

                    <div id="spinner" class="text-center mb-3" style="display:none;">
                        <div class="spinner-border text-success" role="status"></div>
                        <p class="mt-2">Procesando imagen... por favor espere.</p>
                    </div>

                    <button type="submit" class="btn btn-success w-100 py-3">Validar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/tesseract.js@4.1.1/dist/tesseract.min.js"></script>
    <script>
        document.getElementById("form-cedula").addEventListener("submit", async function (e) {
            e.preventDefault();

            const fileInput = document.getElementById("fotoCedula");
            const cedulaOriginal = document.getElementById("cedulaOriginal").value.replace(/-/g, '').trim();

            if (!fileInput.files.length) {
                alert("Debe seleccionar una imagen de la cédula.");
                return;
            }

            const image = fileInput.files[0];
            document.getElementById("spinner").style.display = "block";

            try {
                const { data: { text } } = await Tesseract.recognize(
                    image,
                    'spa',
                    { logger: m => console.log(m) }
                );

                const textoExtraido = text.replace(/\s+/g, '').replace(/-/g, '').trim();
                const cedulaDetectada = textoExtraido.match(/\d{11}/)?.[0];

                if (!cedulaDetectada) {
                    alert("No pudimos leer la cédula. Asegúrese de que la imagen esté clara y bien iluminada.");
                    return;
                }

                if (cedulaDetectada !== cedulaOriginal) {
                    alert("La cédula extraída no coincide con la ingresada. Intente nuevamente.");
                    return;
                }

                window.location.href = `/Elector/ListarPuestos?cedula=${cedulaOriginal}`;
            } catch (error) {
                console.error("Error Tesseract:", error.message || error);
                alert("Ocurrió un error al procesar la imagen.");
            } finally {
                document.getElementById("spinner").style.display = "none";
            }
        });
    </script>

    @if (!string.IsNullOrEmpty(Model.MensajeOCR))
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'OCR',
                text: '@Model.MensajeOCR'
            });
        </script>
    }
}
