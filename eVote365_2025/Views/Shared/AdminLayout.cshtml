<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - eVote365</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/eVote365_2025.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
</head>
<body class="admin-shell">
    <div class="shell-backdrop"></div>
    <header class="shell-header">
        <nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Admin">
                    <i class="bi bi-shield-check me-2"></i>eVote365 Admin
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="adminNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="PuestoElectivo" asp-action="Index"><i class="bi bi-diagram-3 me-1"></i>Puestos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Ciudadano" asp-action="Index"><i class="bi bi-people me-1"></i>Ciudadanos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="PartidoPolitico" asp-action="Index"><i class="bi bi-flag me-1"></i>Partidos</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Usuario" asp-action="Index"><i class="bi bi-person-gear me-1"></i>Usuarios</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="AsignacionDirigentePolitico" asp-action="Index"><i class="bi bi-link-45deg me-1"></i>Dirigentes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Eleccion" asp-action="Index"><i class="bi bi-bar-chart-line me-1"></i>Elecciones</a></li>
                    </ul>
                    <a class="btn btn-admin-ghost btn-sm" asp-controller="Login" asp-action="Logout">
                        <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesión
                    </a>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="shell-main container py-4">
        @RenderBody()
    </main>

    <footer class="shell-footer">
        <div class="container">
            <span>&copy; 2025 - eVote365 - Panel Administrador</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
