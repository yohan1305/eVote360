<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Votación</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/elector.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
</head>
<body class="elector-shell">
    <div class="shell-backdrop"></div>
    <header class="shell-header">
        <nav class="navbar navbar-expand-lg navbar-dark elector-navbar">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Elector" asp-action="VerificarCedula">
                    <i class="bi bi-check2-square me-2"></i>Sistema de Votación
                </a>
                <div class="d-flex align-items-center gap-2">
                    <a class="btn btn-elector-ghost btn-sm" asp-controller="Elector" asp-action="VerificarCedula">Inicio</a>
                    <a class="btn btn-elector-ghost btn-sm" asp-controller="Login" asp-action="Index">Acceder</a>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="shell-main container py-4">
        @RenderBody()
    </main>

    <footer class="shell-footer">
        <div class="container">
            <small>&copy; @DateTime.Now.Year - Sistema de Votación</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
